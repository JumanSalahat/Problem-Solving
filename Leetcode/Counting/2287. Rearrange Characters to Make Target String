class Solution {
public:
    int rearrangeCharacters(string s, string target) {
        int freq1[26]={0};
        for(int i=0;i<s.size();i++)
        {
            freq1[s[i]-'a']++;
        }

        int freq2[26]={0};
        for(int i=0;i<target.size();i++)
        {
            freq2[target[i]-'a']++;
        }
        
        // انتبااه .. مهم جداً
        int ans=INT_MAX;
        for(int i=0;i<26;i++)
        {
            if(freq2[i] != 0)
            {
               int value=freq1[i]/freq2[i];
               ans=min(ans,value);
            }
        }
        
        return ans;
    }
};
